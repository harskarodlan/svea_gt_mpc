<?xml version="1.0"?>
<launch>
    <!-- Launch file arguments -->
    
    <arg name="is_sim"          default="true"/>
    <arg name="use_foxglove"    default="true"/>
    
    <!-- FOR FLOOR2 -->
    <!--
    <arg name="initial_pose_x_b"  default="-6.9"/>
    <arg name="initial_pose_y_b"  default="-15.4"/>
    <arg name="initial_pose_a"  default="+0.9"/>

    <arg name="initial_pose_x_a"  default="-5.2"/>
    <arg name="initial_pose_y_a"  default="-12.4"/>
    -->

    <!-- FOR SML -->
    <arg name="initial_pose_x_b"  default="0.5"/>
    <arg name="initial_pose_y_b"  default="-5.0"/>
    <arg name="initial_pose_a"  default="+1.57079632679"/>

    <arg name="initial_pose_x_a"  default="0.5"/>
    <arg name="initial_pose_y_a"  default="0.0"/>

    <arg name="points" default="'[[-2.3, -7.1], [10.5, 11.7], [5.7,  15.0], [-7.0, -4.0]]'"/>

    <let name="map" value="floor2"/>

    <!-- Start Map Server and Foxglove -->
    <include file="$(find-pkg-share svea_core)/launch/map_and_foxglove.xml">
        <arg name="map" value="$(var map)" />
        <arg name="use_foxglove" value="$(var use_foxglove)" />
    </include>




    <!-- Real SVEA -->
    <!-- TO BE FIXED-->
    <group unless="$(var is_sim)">

        <let name="name" value="self"/>

        <include file="$(find-pkg-share svea_core)/launch/svea.xml">
            <arg name="is_sim" value="$(var is_sim)"/>
            <arg name="initial_pose_x" value="$(var initial_pose_x_a)" />
            <arg name="initial_pose_y" value="$(var initial_pose_y_a)" />
            <arg name="initial_pose_a" value="$(var initial_pose_a)" />
            <arg name="map" value="$(var map)" />
        </include>

        <push-ros-namespace namespace="$(var name)"/>
        
        <!-- Start overtake -->
        <node name="overtake" pkg="gt_mpc" exec="overtake.py" output="screen">
            <param name="is_sims" value="$(var is_sim)"/>
            <param name="points" value="$(var points)" />
            <param name="localization/base_frame" value="$(var name)/base_link"/>
        </node>
    </group>
    



    <!-- SIMULATION-->
    <!-- SVEA-A -->
    <group if="$(var is_sim)">
        <let name="name" value="svea_a"/>

        <include file="$(find-pkg-share svea_core)/launch/svea.xml">
            <arg name="name" value="$(var name)" />
            <arg name="is_sim" value="$(var is_sim)"/>
            <arg name="initial_pose_x" value="$(var initial_pose_x_a)"/>
            <arg name="initial_pose_y" value="$(var initial_pose_y_a)"/>
            <arg name="initial_pose_a" value="$(var initial_pose_a)"/>
            <arg name="map" value="$(var map)"/>
        </include>

        <push-ros-namespace namespace="$(var name)"/>
        
        <!-- Start bridge node for SVEA-A-->
        <node name="car_bridge" pkg="gt_mpc" exec="car_bridge.py" output="screen">
            <param name="is_sim" value="$(var is_sim)"/>
            <param name="localization/base_frame" value="$(var name)/base_link"/>
            <!-- Allow namespace -->
            <param name="steering_top" value="lli/ctrl/steering"/>
            <param name="throttle_top" value="lli/ctrl/throttle"/>
            <param name="highgear_top" value="lli/ctrl/highgear"/>
            <param name="diff_top" value="lli/ctrl/diff"/>
        </node>

    </group>

    <!-- SVEA-B -->
    <group if="$(var is_sim)">
        <let name="name" value="svea_b"/>

        <include file="$(find-pkg-share svea_core)/launch/svea.xml">
            <arg name="name" value="$(var name)" />
            <arg name="is_sim" value="$(var is_sim)"/>
            <arg name="initial_pose_x" value="$(var initial_pose_x_b)"/>
            <arg name="initial_pose_y" value="$(var initial_pose_y_b)"/>
            <arg name="initial_pose_a" value="$(var initial_pose_a)"/>
            <arg name="map" value="$(var map)"/>
        </include>

        <push-ros-namespace namespace="$(var name)"/>
        
        <!-- Start bridge node for SVEA-B-->
        <node name="car_bridge" pkg="gt_mpc" exec="car_bridge.py" output="screen">
            <param name="is_sim" value="$(var is_sim)"/>
            <param name="localization/base_frame" value="$(var name)/base_link"/>
            <!-- Allow namespace -->
            <param name="steering_top" value="lli/ctrl/steering"/>
            <param name="throttle_top" value="lli/ctrl/throttle"/>
            <param name="highgear_top" value="lli/ctrl/highgear"/>
            <param name="diff_top" value="lli/ctrl/diff"/>
        </node>

    </group>

    <!--Centralized gt-mpc controller-->
    <group if="$(var is_sim)">
        <!-- Start overtake -->
        <node name="overtake" pkg="gt_mpc" exec="overtake.py" output="screen">
            <param name="initial_pose_x_a" value="$(var initial_pose_x_a)"/>
            <param name="initial_pose_y_a" value="$(var initial_pose_y_a)"/>
            <param name="initial_pose_x_b" value="$(var initial_pose_x_b)"/>
            <param name="initial_pose_y_b" value="$(var initial_pose_y_b)"/>
        </node>
    </group>

</launch>
